# ── Camper-Reiseplaner – Konfiguration ────────────────────────────────────────
# Diese Datei nach ".env" kopieren und ausfüllen:  cp .env.example .env
# docker compose liest .env beim Start automatisch ein.

# Google-Maps-API-Key (PFLICHT – ohne ihn bleibt die Karte leer).
# Anlegen in der Google Cloud Console, benötigte APIs:
#   Maps JavaScript API, Directions API, Geocoding API, Places API (New)
# Unbedingt per HTTP-Referrer auf deine Domain beschränken (siehe README),
# da der Key im Browser sichtbar ist.
GOOGLE_MAPS_API_KEY=

# Host-Port, unter dem der Container erreichbar ist (Standard: 8082).
# Der Container selbst lauscht immer auf 8000.
CAMPER_PORT=8082
