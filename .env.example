# ── Camper-Reiseplaner – Konfiguration ────────────────────────────────────────
# Diese Datei nach ".env" kopieren und ausfüllen:  cp .env.example .env
# docker compose liest .env beim Start automatisch ein.

# ── Google Maps ───────────────────────────────────────────────────────────────
# 1) RENDER-KEY (PFLICHT) – lädt die Karte im Browser, ist dort sichtbar.
#    Google Cloud Console: nur "Maps JavaScript API" aktivieren und den Key
#    per HTTP-Referrer auf deine Domain beschränken (z. B. https://camper.example.de/*).
GOOGLE_MAPS_API_KEY=

# 2) SERVER-KEY (empfohlen) – für Directions/Places/Geocoding, die server-seitig
#    laufen und den Browser NIE erreichen. Google Cloud Console: diese drei APIs
#    aktivieren und den Key per IP-Adresse auf deinen Server beschränken (KEINE
#    Referrer-Beschränkung – Legacy-Webservices lehnen die ab). Leer lassen =
#    Fallback auf den Render-Key oben (nur für erste Tests sinnvoll).
GOOGLE_MAPS_SERVER_KEY=
# Referer-Header, den der Server mitschickt (nur relevant, solange als Server-Key
# ein referrer-beschränkter Key dient). Auf deine Domain setzen.
GOOGLE_KEY_REFERER=https://camper.example.de/

# ── Login / Konten (Multi-User) ───────────────────────────────────────────────
# Die App hat einen eingebauten Login (E-Mail + Passwort, Session-Cookie).
# Jeder Nutzer sieht nur seine eigenen Reisen.

# Signaturschlüssel für das Session-Cookie (PFLICHT in Produktion!).
# Erzeugen z. B. mit:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Admin-Konto: E-Mail + Passwort werden beim Start geseedet. Bestehende Reisen
# ohne Eigentümer werden diesem Konto zugeordnet. Passwort hier = Quelle der Wahrheit.
ADMIN_USER=admin@example.de
ADMIN_PASSWORD=

# Weitere freigeschaltete Nutzer als JSON-Liste [{email, code}, …]. Nur diese
# E-Mails (plus ADMIN_USER) dürfen sich anmelden. Der "code" ist ein persönlicher
# EINMALCODE, mit dem der Nutzer sein Passwort einmalig setzt (danach verbraucht;
# für ein Reset einen neuen Code hinterlegen). Leer = nur der Admin kann rein.
# Beispiel: MEMBERS=[{"email":"anja@example.de","code":"mox2-xtra-35wz"}]
MEMBERS=[]

# Cookie nur über HTTPS senden (1 = ja, Standard). Für rein lokalen HTTP-Test auf 0.
COOKIE_SECURE=1

# Login-Versuche pro IP je 5-Minuten-Fenster (Brute-Force-Bremse, Standard 20).
LOGIN_RATELIMIT=20

# ── Betrieb ───────────────────────────────────────────────────────────────────
# Host-Port, unter dem der Container erreichbar ist (Standard: 8082).
# Der Container selbst lauscht immer auf 8000.
CAMPER_PORT=8082
